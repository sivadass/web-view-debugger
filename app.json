{
  "expo": {
    "name": "web-view-debugger",
    "slug": "web-view-debugger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "webviewdebugger",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.webviewdebugger.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Web View Debugger to access your camera to scan QR codes.",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "22e2da5f-63e0-4cf4-97f5-0f43cc998f9d"
      }
    },
    "owner": "kethnah"
  }
}
